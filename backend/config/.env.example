APP_NAME=lazyops-server
APP_ENV=development

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=debug

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lazyops
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Bangkok
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=50

JWT_SECRET=change-me-in-production
JWT_ISSUER=lazyops-server
JWT_EXPIRES_IN=24h
PAT_EXPIRES_IN=720h

ALLOWED_ORIGINS=*
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
CLI_LOGIN_RATE_LIMIT_RPS=0.5
CLI_LOGIN_RATE_LIMIT_BURST=3

SEED_ADMIN_EMAIL=admin@lazyops.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=System Admin

WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
WS_PING_PERIOD=30s
WS_PONG_WAIT=60s

GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/auth/google/success
GOOGLE_OAUTH_FAILURE_REDIRECT_URL=http://localhost:3000/login
GOOGLE_OAUTH_STATE_TTL=10m
