APP_NAME=lazyops-server
APP_ENV=development

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=debug

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lazyops
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Bangkok
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=50

JWT_SECRET=change-me-in-production
JWT_ISSUER=lazyops-server
JWT_EXPIRES_IN=24h

ALLOWED_ORIGINS=*
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

SEED_ADMIN_EMAIL=admin@lazyops.local
SEED_ADMIN_PASSWORD=admin123!
SEED_ADMIN_NAME=System Admin

WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
WS_PING_PERIOD=30s
WS_PONG_WAIT=60s

GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth/github/callback
GITHUB_OAUTH_ENABLED=true

GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_NAME=
GITHUB_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth/github/callback
GITHUB_APP_WEBHOOK_URL=https://example.com/api/v1/integrations/github/webhook
GITHUB_APP_INSTALL_URL=https://github.com/apps/lazyopshj/installations/new
