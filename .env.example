APP_NAME=lazyops-server
APP_ENV=production

# Docker image settings for production compose/workflow deploy
BACKEND_IMAGE=tawn/lazyops-backend
FRONTEND_IMAGE=tawn/lazyops-frontend
AGENT_IMAGE=tawn/lazyops-agent
IMAGE_TAG=latest
AGENT_IMAGE_TAG=latest
AGENT_DEFAULT_IMAGE=tawn/lazyops-agent:latest
BACKEND_PORT=8080
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80
NEXT_PUBLIC_API_URL=http://localhost:8080
INTERNAL_API_URL=http://backend:8080
NEXT_PUBLIC_AGENT_IMAGE_DEFAULT=tawn/lazyops-agent:latest
NEXT_PUBLIC_FEATURE_FLAGS=mock_mode=false,ux_three_step_flow=true,module_instances=true,module_deployments=true

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=release

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lazyops
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Bangkok
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=50

JWT_SECRET=change-me-in-production
JWT_ISSUER=lazyops-server
JWT_EXPIRES_IN=24h
PAT_EXPIRES_IN=720h
BOOTSTRAP_TOKEN_TTL=15m
AGENT_TOKEN_TTL=720h

ALLOWED_ORIGINS=*
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
CLI_LOGIN_RATE_LIMIT_RPS=0.5
CLI_LOGIN_RATE_LIMIT_BURST=3

SEED_ADMIN_EMAIL=admin@lazyops.local
SEED_ADMIN_PASSWORD=admin123!
SEED_ADMIN_NAME=System Admin

WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
WS_PING_PERIOD=30s
WS_PONG_WAIT=60s

GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/dashboard
GOOGLE_OAUTH_FAILURE_REDIRECT_URL=http://localhost:3000/login
GOOGLE_OAUTH_STATE_TTL=10m

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_SCOPES=read:user,user:email,read:org,repo
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/oauth/github/callback
GITHUB_OAUTH_ENABLED=true
GITHUB_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/dashboard
GITHUB_OAUTH_FAILURE_REDIRECT_URL=http://localhost:3000/login
GITHUB_OAUTH_STATE_TTL=10m

GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_NAME=
GITHUB_APP_CALLBACK_URL=http://localhost:3000/integrations/github
GITHUB_APP_WEBHOOK_URL=https://example.com/api/v1/integrations/github/webhook
GITHUB_APP_INSTALL_URL=https://github.com/apps/lazyopshj/installations/new

# Build Worker (auto-builds Docker images from user repos)
BUILD_WORKER_ENABLED=false
BUILD_WORKER_POLL_INTERVAL=5s
BUILD_WORKER_MAX_CONCURRENCY=2
BUILD_REGISTRY_HOST=
BUILD_REGISTRY_USER=
BUILD_REGISTRY_PASS=
BUILD_NIXPACKS_BIN=nixpacks
BUILD_DOCKER_BIN=docker
