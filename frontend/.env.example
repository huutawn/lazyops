NEXT_PUBLIC_APP_NAME=LazyOps Console
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_AGENT_IMAGE_DEFAULT=tawn/lazyops-agent:latest

# Set to "true" to enable MSW mock mode for development
NEXT_PUBLIC_MOCK_MODE=false

# Comma-separated feature flags: key=true,key=false
NEXT_PUBLIC_FEATURE_FLAGS=mock_mode=false,ux_three_step_flow=true,module_instances=true,module_deployments=true
